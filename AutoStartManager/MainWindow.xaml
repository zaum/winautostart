<Window x:Class="AutoStartManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:models="clr-namespace:AutoStartManager.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="AutoStart Manager - Manage Windows startup applications"
        Height="600" Width="550"
        MinHeight="400" MinWidth="450"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="White">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" UseAeroCaptionButtons="False" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <ResourceDictionary>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="FlatButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="border" Property="Background" Value="#333333"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="border" Property="Background" Value="#252525"/>
                    </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PinButton" TargetType="ToggleButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    CornerRadius="0">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#505050"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#252525"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter Property="Content" Value="📌"/>
                    </Trigger>
                    <Trigger Property="IsChecked" Value="False">
                        <Setter Property="Content" Value="📍"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid Background="Transparent" Width="24" Height="24">
                                <Border Width="22" Height="22"
                                        CornerRadius="4"
                                        Background="#3D3D3D"
                                        BorderThickness="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="✓"
                                               Foreground="#FFFFFF"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="FlatScrollBar" TargetType="ScrollBar">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Width" Value="8"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Effect" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Border Background="Transparent" BorderThickness="0">
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border x:Name="thumb" CornerRadius="4" Background="#555555"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="thumb" Property="Background" Value="#777777"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollViewer">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollViewer">
                            <Grid>
                                <ScrollContentPresenter CanContentScroll="{TemplateBinding CanContentScroll}"
                                                        Margin="{TemplateBinding Padding}"/>
                                <ScrollBar x:Name="PART_VerticalScrollBar"
                                           Style="{StaticResource FlatScrollBar}"
                                           Value="{TemplateBinding VerticalOffset}"
                                           Maximum="{TemplateBinding ScrollableHeight}"
                                           ViewportSize="{TemplateBinding ViewportHeight}"
                                           Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Stretch"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="Transparent">
            <Grid>
                <TextBlock Text="AutoStart Manager — Manage startup apps"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <ToggleButton x:Name="PinToggle"
                                  IsChecked="True"
                                  ToolTip="Always on top"
                                  Click="PinToggle_Click"
                                   Width="38" Height="40"
                                   FontSize="14"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   Foreground="#CCCCCC"
                                   Style="{StaticResource PinButton}"
                                   shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    <Button x:Name="MinimizeButton"
                            ToolTip="Minimize"
                            Content="─"
                            Click="MinimizeButton_Click"
                            Width="46" Height="40"
                            FontSize="16"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#CCCCCC"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#505050"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="MaximizeButton"
                            ToolTip="Maximize"
                            Content="☐"
                            Click="MaximizeButton_Click"
                            Width="46" Height="40"
                            FontSize="14"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#CCCCCC"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#505050"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button x:Name="CloseButton"
                            ToolTip="Close"
                            Content="✕"
                            Click="CloseButton_Click"
                            Width="46" Height="40"
                            FontSize="16"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#CCCCCC"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C42B1C"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Padding="32,12,32,18" Background="Transparent">
            <Grid>
                <Border CornerRadius="8"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="#555555">
                    <Grid>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search startup items..."
                                 Background="Transparent"
                                 Foreground="White"
                                 CaretBrush="White"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 MinHeight="38"
                                 Padding="10,0"
                                 Margin="0,0,30,0"/>
                        <TextBlock Text="Filter startup items..."
                                   FontSize="13"
                                   Foreground="#777777"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Padding="12,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSearchText}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                                <Button Command="{Binding ClearSearchCommand}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Width="28" Height="28"
                                        Margin="0,0,4,0"
                                        Padding="0"
                                        FontSize="14"
                                        Content="✕"
                                        BorderThickness="0"
                                        Foreground="#999999"
                                        Style="{StaticResource FlatButton}"
                                        Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      Margin="0,8,0,8"
                      VerticalScrollBarVisibility="Auto">
             <ItemsControl ItemsSource="{Binding Items}"
                          BorderThickness="0"
                          Background="Transparent"
                          Foreground="White">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:StartupItem">
                        <Border Padding="12,6" Margin="16,2,16,2"
                                Background="Transparent"
                                CornerRadius="6"
                                BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                          Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                          CommandParameter="{Binding}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"
                                          Foreground="White"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="White"/>
                                    <TextBlock Text="{Binding SourceDisplay}"
                                               FontSize="11"
                                               Foreground="#999999"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="📁"
                                            ToolTip="Open file location"
                                            Command="{Binding DataContext.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource FlatButton}"
                                            FontSize="14"
                                            Height="32" Width="32"
                                            Padding="0"
                                            Margin="0,0,6,0"/>
                                    <Button Content="🗑"
                                            ToolTip="Remove from startup"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Foreground="#CC6666"
                                            FontSize="14"
                                            Height="32" Width="32"
                                            Padding="0"
                                            Margin="6,0,0,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                                <Setter Property="Foreground" Value="#CC6666"/>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="1"
                Margin="16,12,16,4"
                BorderThickness="1"
                BorderBrush="#444444"
                CornerRadius="8"
                Background="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="10,10,10,0"
                        CornerRadius="6"
                        Background="#3D3D3D"
                        BorderThickness="1"
                        BorderBrush="#555555">
                    <Grid>
                        <TextBox x:Name="AppSearchBox"
                                 Text="{Binding AppSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 Foreground="White"
                                 CaretBrush="White"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 MinHeight="40"
                                 Padding="10,0,30,0"
                                 Margin="0,0,0,0"/>
                        <TextBlock Text="Search installed apps..."
                                   FontSize="12"
                                   Foreground="White"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Padding="12,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAppSearchText}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Command="{Binding ClearAppSearchCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Width="24" Height="24"
                                Margin="0,0,4,0"
                                Padding="0"
                                FontSize="12"
                                Content="✕"
                                BorderThickness="0"
                                Foreground="#999999"
                                Style="{StaticResource FlatButton}"
                                Visibility="{Binding HasAppSearchText, Converter={StaticResource BoolToVis}}"/>
                     </Grid>
                 </Border>

                 <ScrollViewer Grid.Row="1"
                              Margin="6,6,6,4"
                              MaxHeight="220"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasAppSearchText, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding InstalledAppsView}"
                                  Background="Transparent"
                                  Foreground="White">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:InstalledApp">
                                <Border Padding="8,4"
                                        Background="Transparent"
                                        CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding TargetPath}"
                                                       FontSize="10"
                                                       Foreground="#999999"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="300"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="+"
                                                ToolTip="Add to startup"
                                                Click="AddInstalledApp_Click"
                                                Style="{StaticResource FlatButton}"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Foreground="#66CC66"
                                                Height="28" Width="28"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Margin="10,0,10,10"
                        Padding="16,20"
                        BorderThickness="0"
                        CornerRadius="6"
                        Background="Transparent"
                        AllowDrop="True"
                        PreviewDragOver="DropZone_PreviewDragOver"
                        PreviewDrop="DropZone_PreviewDrop"
                        MouseLeftButtonDown="DropZone_MouseLeftButtonDown"
                        Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <TextBlock Text="📂"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Click or drag to add file"
                                   FontSize="11"
                                   Foreground="#999999"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.RowSpan="4"
                x:Name="ToastBorder"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                MaxWidth="550"
                Margin="0,0,0,50"
                Padding="28,14"
                CornerRadius="8"
                Background="#2D2D2D"
                BorderThickness="1"
                BorderBrush="#555555"
                Panel.ZIndex="999"
                Opacity="0"
                IsHitTestVisible="False">
            <TextBlock x:Name="ToastText"
                       Foreground="White"
                       FontSize="16"
                       TextAlignment="Center"
                       TextWrapping="NoWrap"/>
        </Border>
    </Grid>
</Window>
