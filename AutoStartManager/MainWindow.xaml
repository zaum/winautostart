<Window x:Class="AutoStartManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:models="clr-namespace:AutoStartManager.Models"
        Title="AutoStart Manager"
        Height="600" Width="550"
        MinHeight="400" MinWidth="450"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="White">
    <Window.Resources>
        <ResourceDictionary>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="FlatButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2A2A2A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid Background="Transparent" Width="24" Height="24">
                                <Border Width="22" Height="22"
                                        CornerRadius="4"
                                        Background="#3D3D3D"
                                        BorderThickness="0"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="✓"
                                               Foreground="#FFFFFF"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="2" Padding="16,12,16,18" Background="Transparent">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Margin="44,0,0,0"
                        CornerRadius="8"
                        Background="Transparent"
                        BorderThickness="1"
                        BorderBrush="#555555">
                    <Grid>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search startup items..."
                                 Background="Transparent"
                                 Foreground="White"
                                 CaretBrush="White"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 Margin="0,0,30,0"/>
                        <TextBlock Text="Filter startup items..."
                                   FontSize="13"
                                   Foreground="#777777"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Padding="12,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSearchText}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Command="{Binding ClearSearchCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Width="28" Height="28"
                                Margin="0,0,4,0"
                                Padding="0"
                                FontSize="14"
                                Content="✕"
                                BorderThickness="0"
                                Visibility="{Binding HasSearchText, Converter={StaticResource BoolToVis}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="#999999"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#555555"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#444444"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>
                <Button Grid.Column="1"
                        Margin="10,0,0,0"
                        Content="⟳"
                        ToolTip="Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource FlatButton}"
                        Height="40" Width="40"
                        FontSize="24"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="0,8,0,8"
                      VerticalScrollBarVisibility="Hidden">
             <ItemsControl ItemsSource="{Binding Items}"
                          BorderThickness="0"
                          Background="Transparent"
                          Foreground="White">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:StartupItem">
                        <Border Padding="12,6" Margin="16,2,16,2"
                                Background="Transparent"
                                CornerRadius="6"
                                BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                          Command="{Binding DataContext.ToggleCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                          CommandParameter="{Binding}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"
                                          Foreground="White"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="White"/>
                                    <TextBlock Text="{Binding SourceDisplay}"
                                               FontSize="11"
                                               Foreground="#999999"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Content="📁"
                                            ToolTip="Open file location"
                                            Command="{Binding DataContext.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource FlatButton}"
                                            FontSize="14"
                                            Height="32" Width="32"
                                            Padding="0"
                                            Margin="0,0,6,0"/>
                                    <Button Content="🗑"
                                            ToolTip="Remove from startup"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Foreground="#CC6666"
                                            FontSize="14"
                                            Height="32" Width="32"
                                            Padding="0"
                                            Margin="6,0,0,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource FlatButton}">
                                                <Setter Property="Foreground" Value="#CC6666"/>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="0"
                Margin="16,12,16,4"
                BorderThickness="1"
                BorderBrush="#444444"
                CornerRadius="8"
                Background="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="10,10,10,0"
                        CornerRadius="6"
                        Background="#3D3D3D"
                        BorderThickness="1"
                        BorderBrush="#555555">
                    <Grid>
                        <TextBox Text="{Binding AppSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 LostFocus="AppSearchBox_LostFocus"
                                 Background="Transparent"
                                 Foreground="White"
                                 CaretBrush="White"
                                 BorderThickness="0"
                                 VerticalContentAlignment="Center"
                                 MinHeight="32"
                                 Padding="10,0,30,0"
                                 Margin="0,0,0,0"/>
                        <TextBlock Text="Search installed apps..."
                                   FontSize="12"
                                   Foreground="#777777"
                                   IsHitTestVisible="False"
                                   VerticalAlignment="Center"
                                   Padding="12,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasAppSearchText}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Command="{Binding ClearAppSearchCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Width="24" Height="24"
                                Margin="0,0,4,0"
                                Padding="0"
                                FontSize="12"
                                Content="✕"
                                BorderThickness="0"
                                Visibility="{Binding HasAppSearchText, Converter={StaticResource BoolToVis}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="#999999"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#555555"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#444444"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              Margin="6,6,6,4"
                              MaxHeight="220"
                              VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding HasAppSearchText, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding InstalledAppsView}"
                                  Background="Transparent"
                                  Foreground="White">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="models:InstalledApp">
                                <Border Padding="8,4"
                                        Background="Transparent"
                                        CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Content="+"
                                                ToolTip="Add to startup"
                                                Click="AddInstalledApp_Click"
                                                Style="{StaticResource FlatButton}"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Foreground="#66CC66"
                                                Height="28" Width="28"
                                                VerticalAlignment="Center"
                                                Margin="0,0,4,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding TargetPath}"
                                                       FontSize="10"
                                                       Foreground="#999999"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="300"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Margin="10,0,10,10"
                        Padding="16,20"
                        BorderThickness="0"
                        CornerRadius="6"
                        Background="Transparent"
                        AllowDrop="True"
                        PreviewDragOver="DropZone_PreviewDragOver"
                        PreviewDrop="DropZone_PreviewDrop"
                        MouseLeftButtonDown="DropZone_MouseLeftButtonDown"
                        Cursor="Hand">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <TextBlock Text="📂"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Click or drag to add file"
                                   FontSize="11"
                                   Foreground="#999999"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
